# Local development
DATABASE_URL=postgresql://adrine:adrine_dev@localhost:5432/adrine?schema=public
NODE_ENV=development

# Services
PORT_KERNEL=3001
PORT_DOMAIN=3002
KERNEL_API_URL=http://localhost:3001
NEXT_PUBLIC_DOMAIN_API_URL=http://localhost:3002/api/docs

# Hospital OS (Vite)
VITE_KERNEL_API_URL=http://localhost:3001
VITE_DOMAIN_API_URL=http://localhost:3002
VITE_API_BASE_URL=http://localhost:3002
VITE_DEV_TENANT_ID=tenant_dev

# Patient app (Next.js)
NEXT_PUBLIC_KERNEL_API_URL=http://localhost:3001
NEXT_PUBLIC_DOMAIN_API_URL=http://localhost:3002
NEXT_PUBLIC_DEV_TENANT_ID=tenant_dev
NEXT_PUBLIC_PLATFORM_RUNTIME=true

# Temporal
TEMPORAL_ADDRESS=127.0.0.1:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=adrine-healthcare

# AI Gateway (Python)
AI_GATEWAY_PORT=8000

# Navayu MSK AI summary (domain-api — set on Coolify domain-api service, not Hospital OS)
# OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
