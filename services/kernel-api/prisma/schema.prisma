generator client {

  provider = "prisma-client-js"

  output   = "../src/generated/prisma"

}



datasource db {

  provider = "postgresql"

  url      = env("DATABASE_URL")

}



/// Append-only audit entries. RLS policies are applied at migration time in production.

model AuditLog {

  id        String   @id @default(cuid())

  tenantId  String   @map("tenant_id")

  actorId   String?  @map("actor_id")

  action    String

  resource  String

  metadata  Json?

  createdAt DateTime @default(now()) @map("created_at")



  @@index([tenantId, createdAt])

  @@map("audit_logs")

}



model Organization {

  id        String   @id @default(cuid())

  tenantId  String   @unique @map("tenant_id")

  name      String

  legalName String?  @map("legal_name")

  parentOrgId String? @map("parent_org_id")

  hierarchyLevel Int @default(0) @map("hierarchy_level")

  createdAt DateTime @default(now()) @map("created_at")



  branches Branch[]

  policies PolicyDefinition[]



  @@map("organizations")

}



model Branch {

  id             String   @id @default(cuid())

  tenantId       String   @map("tenant_id")

  organizationId String   @map("organization_id")

  parentBranchId String?  @map("parent_branch_id")

  code           String

  name           String

  timezone       String   @default("Asia/Kolkata")

  isActive       Boolean  @default(true) @map("is_active")

  moduleFlags    Json?    @map("module_flags")

  createdAt      DateTime @default(now()) @map("created_at")



  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  configs      BranchConfig[]

  users        PlatformUser[]

  policyOverrides PolicyOverride[]

  departments  Department[]

  staffAssignments StaffAssignment[]



  @@unique([tenantId, code])

  @@map("branches")

}



model PlatformUser {

  id        String   @id @default(cuid())

  tenantId  String   @map("tenant_id")

  branchId  String   @map("branch_id")

  email     String

  fullName  String   @map("full_name")

  role      String

  passwordHash String? @map("password_hash")

  isActive  Boolean  @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")



  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)



  @@unique([tenantId, email])

  @@map("platform_users")

}



model BranchConfig {

  id        String   @id @default(cuid())

  tenantId  String   @map("tenant_id")

  branchId  String   @map("branch_id")

  key       String

  value     Json

  updatedAt DateTime @updatedAt @map("updated_at")



  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)



  @@unique([branchId, key])

  @@map("branch_configs")

}



model UsageMeter {

  id         String   @id @default(cuid())

  tenantId   String   @map("tenant_id")

  branchId   String?  @map("branch_id")

  metric     String

  quantity   Int      @default(1)

  resourceId String?  @map("resource_id")

  metadata   Json?

  recordedAt DateTime @default(now()) @map("recorded_at")



  @@index([tenantId, metric, recordedAt])

  @@map("usage_meters")

}



model Subscription {

  id        String   @id @default(cuid())

  tenantId  String   @unique @map("tenant_id")

  plan      String   @default("starter")

  status    String   @default("active")

  limits    Json?

  createdAt DateTime @default(now()) @map("created_at")



  @@map("subscriptions")

}

model PolicyDefinition {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  organizationId String   @map("organization_id")
  key            String
  label          String
  defaultValue   Json     @map("default_value")
  schemaVersion  Int      @default(1) @map("schema_version")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@map("policy_definitions")
}

model PolicyOverride {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  branchId   String   @map("branch_id")
  policyKey  String   @map("policy_key")
  value      Json
  updatedAt  DateTime @updatedAt @map("updated_at")

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, policyKey])
  @@map("policy_overrides")
}

model RoleTemplate {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  code        String
  label       String
  permissions Json
  createdAt   DateTime @default(now()) @map("created_at")

  assignments StaffAssignment[]

  @@unique([tenantId, code])
  @@map("role_templates")
}

model StaffAssignment {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  branchId       String   @map("branch_id")
  userId         String   @map("user_id")
  roleTemplateId String   @map("role_template_id")
  departmentCode String?  @map("department_code")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  roleTemplate RoleTemplate @relation(fields: [roleTemplateId], references: [id], onDelete: Cascade)

  @@index([tenantId, branchId, userId])
  @@map("staff_assignments")
}

model DelegationGrant {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  fromUserId   String    @map("from_user_id")
  toUserId     String    @map("to_user_id")
  permissions  Json
  validFrom    DateTime  @map("valid_from")
  validUntil   DateTime? @map("valid_until")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([tenantId, toUserId])
  @@map("delegation_grants")
}

model ApprovalChain {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  domain       String
  steps        Json
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([tenantId, domain])
  @@map("approval_chains")
}

model Department {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  branchId  String   @map("branch_id")
  code      String
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, code])
  @@map("departments")
}

// --- Productization: tenant provisioning ---
model TenantSignup {
  id         String   @id @default(cuid())
  tenantId   String   @unique @map("tenant_id")
  orgName    String   @map("org_name")
  adminEmail String   @map("admin_email")
  adminName  String?  @map("admin_name")
  status     String   @default("pending")
  createdAt  DateTime @default(now()) @map("created_at")

  sessions OnboardingSession[]

  @@map("tenant_signups")
}

model OnboardingSession {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  signupId     String    @map("signup_id")
  templatePack String?   @map("template_pack")
  progressJson Json      @default("{}") @map("progress_json")
  status       String    @default("in_progress")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  signup TenantSignup     @relation(fields: [signupId], references: [id], onDelete: Cascade)
  steps  OnboardingStep[]

  @@index([tenantId, status])
  @@map("onboarding_sessions")
}

model OnboardingStep {
  id          String   @id @default(cuid())
  sessionId   String   @map("session_id")
  stepKey     String   @map("step_key")
  payload     Json?
  completedAt DateTime @default(now()) @map("completed_at")

  session OnboardingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, stepKey])
  @@map("onboarding_steps")
}

// --- Platform SaaS billing (not patient invoices) ---
model SubscriptionPlan {
  id           String   @id @default(cuid())
  code         String   @unique
  label        String
  isMetered    Boolean  @default(false) @map("is_metered")
  taxRateBps   Int      @default(1800) @map("tax_rate_bps")
  quotaLimits  Json?    @map("quota_limits")
  createdAt    DateTime @default(now()) @map("created_at")

  subscriptions TenantSubscription[]

  @@map("subscription_plans")
}

model TenantSubscription {
  id        String   @id @default(cuid())
  tenantId  String   @unique @map("tenant_id")
  planId    String   @map("plan_id")
  status    String   @default("active")
  startedAt DateTime @default(now()) @map("started_at")
  endsAt    DateTime? @map("ends_at")

  plan SubscriptionPlan @relation(fields: [planId], references: [id])

  @@map("tenant_subscriptions")
}

model UsageRecord {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  branchId   String?  @map("branch_id")
  dimension  String
  quantity   Int      @default(1)
  resourceId String?  @map("resource_id")
  metadata   Json?
  recordedAt DateTime @default(now()) @map("recorded_at")

  @@index([tenantId, dimension, recordedAt])
  @@map("usage_records")
}

model PlatformInvoice {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")
  subtotalCents Int    @map("subtotal_cents")
  taxCents    Int      @map("tax_cents")
  totalCents  Int      @map("total_cents")
  gstRateBps  Int      @default(1800) @map("gst_rate_bps")
  hsnSac      String?  @map("hsn_sac")
  status      String   @default("draft")
  lineItems   Json     @map("line_items")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@map("platform_invoices")
}

model QuotaLimit {
  id        String @id @default(cuid())
  planId    String @map("plan_id")
  dimension String
  cap       Int

  @@unique([planId, dimension])
  @@map("quota_limits")
}

// --- Module entitlements ---
model ModuleCatalog {
  id          String   @id @default(cuid())
  code        String   @unique
  label       String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  entitlements TenantModuleEntitlement[]

  @@map("module_catalog")
}

model TenantModuleEntitlement {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  moduleId  String   @map("module_id")
  enabled   Boolean  @default(true)
  enabledAt DateTime @default(now()) @map("enabled_at")

  module ModuleCatalog @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, moduleId])
  @@map("tenant_module_entitlements")
}

model BranchModuleOverride {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  branchId  String   @map("branch_id")
  moduleCode String  @map("module_code")
  enabled   Boolean
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, branchId, moduleCode])
  @@map("branch_module_overrides")
}

// --- Integrations ---
model ApiKey {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  name         String
  keyPrefix    String   @map("key_prefix")
  keyHash      String   @map("key_hash")
  rateLimitRpm Int      @default(60) @map("rate_limit_rpm")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([tenantId, isActive])
  @@map("api_keys")
}

model WebhookSubscription {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  url       String
  secret    String
  events    Json
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  deliveries WebhookDelivery[]

  @@index([tenantId, isActive])
  @@map("webhook_subscriptions")
}

model WebhookDelivery {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  subscriptionId String   @map("subscription_id")
  eventName      String   @map("event_name")
  payload        Json
  status         String   @default("pending")
  attempts       Int      @default(0)
  lastError      String?  @map("last_error")
  createdAt      DateTime @default(now()) @map("created_at")

  subscription WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@map("webhook_deliveries")
}

model IntegrationConnection {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  provider   String
  config     Json
  status     String   @default("active")
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([tenantId, provider])
  @@map("integration_connections")
}

// --- Production readiness ---
model IdempotencyRecord {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  key       String
  route     String
  response  Json?
  status    String   @default("completed")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  @@unique([tenantId, key])
  @@map("idempotency_records")
}

model PlatformEventOutbox {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  eventName   String    @map("event_name")
  payload     Json
  status      String    @default("pending")
  attempts    Int       @default(0)
  nextRetryAt DateTime? @map("next_retry_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([tenantId, status, nextRetryAt])
  @@map("platform_event_outbox")
}

// --- Operational templates ---
model OperationalTemplatePack {
  id          String   @id @default(cuid())
  code        String   @unique
  label       String
  description String?
  packJson    Json     @map("pack_json")
  createdAt   DateTime @default(now()) @map("created_at")

  instantiations TemplateInstantiation[]

  @@map("operational_template_packs")
}

model TemplateInstantiation {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  branchId  String   @map("branch_id")
  packId    String   @map("pack_id")
  status    String   @default("completed")
  createdAt DateTime @default(now()) @map("created_at")

  pack OperationalTemplatePack @relation(fields: [packId], references: [id])

  @@index([tenantId, branchId])
  @@map("template_instantiations")
}

model TenantMetricsSnapshot {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  metrics   Json
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@map("tenant_metrics_snapshots")
}

model JobQueue {
  id        String   @id @default(cuid())
  tenantId  String?  @map("tenant_id")
  jobType   String   @map("job_type")
  payload   Json
  status    String   @default("pending")
  attempts  Int      @default(0)
  lastError String?  @map("last_error")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@map("job_queue")
}

model DeadLetterEvent {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  eventName String   @map("event_name")
  payload   Json
  error     String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@map("dead_letter_events")
}

/// TOTP MFA enrollment stub — secret stored until verified.
model MfaChallenge {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tenantId  String   @map("tenant_id")
  secret    String
  verified  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, verified])
  @@map("mfa_challenges")
}

/// Revocable user sessions (JWT may reference session id in future).
model UserSession {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  tenantId   String    @map("tenant_id")
  branchId   String    @map("branch_id")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  lastSeenAt DateTime  @default(now()) @map("last_seen_at")

  @@index([userId, revokedAt])
  @@index([tenantId, branchId])
  @@map("user_sessions")
}


