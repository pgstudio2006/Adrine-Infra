generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Patient {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  mrn       String?
  fullName  String   @map("full_name")
  dob       DateTime?
  createdAt DateTime @default(now()) @map("created_at")

  encounters   Encounter[]
  appointments Appointment[]
  crmLeads           CrmLead[]
  crmLifecycleEvents CrmLifecycleEvent[]
  schedulingWaitlist SchedulingWaitlistEntry[]
  invoices     Invoice[]
  opdVisits            OpdVisit[]
  labOrders            LabDiagnosticOrder[]
  radiologyOrders      RadiologyStudyOrder[]
  pharmacyFulfillments PharmacyFulfillment[]
  ipdAdmissions        IpdAdmission[]
  nursingTasks         NursingTask[]
  nursingVitalRounds   NursingVitalRound[]
  nursingNotes         NursingNote[]
  medicationSchedules  MedicationSchedule[]
  dischargeOrchestrations DischargeOrchestration[]
  insuranceAuthorizations InsuranceAuthorization[]
  otCases               OtCase[]
  dialysisSessions      DialysisSession[]

  @@index([tenantId, createdAt])
  @@map("patients")
}

/// Authoritative OPD operational state machine instance.
model OpdVisit {
  id                String    @id @default(cuid())
  tenantId          String    @map("tenant_id")
  branchId          String    @map("branch_id")
  patientId         String    @map("patient_id")
  encounterId       String?   @map("encounter_id")
  appointmentId     String?   @map("appointment_id")
  state             String    @default("intent")
  previousState     String?   @map("previous_state")
  department        String?
  assignedDoctor    String?   @map("assigned_doctor")
  tokenNumber       Int?      @map("token_number")
  complaint         String?
  escalationLevel   Int       @default(0) @map("escalation_level")
  escalationReason  String?   @map("escalation_reason")
  metadata          Json?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  completedAt       DateTime? @map("completed_at")

  patient     Patient              @relation(fields: [patientId], references: [id], onDelete: Cascade)
  transitions OpdVisitTransition[]

  @@index([tenantId, branchId, state])
  @@index([tenantId, patientId, createdAt])
  @@map("opd_visits")
}

model OpdVisitTransition {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  opdVisitId String   @map("opd_visit_id")
  action     String
  fromState  String   @map("from_state")
  toState    String   @map("to_state")
  actorId    String?  @map("actor_id")
  actorRole  String?  @map("actor_role")
  reason     String?
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  visit OpdVisit @relation(fields: [opdVisitId], references: [id], onDelete: Cascade)

  @@index([tenantId, opdVisitId, createdAt])
  @@map("opd_visit_transitions")
}

/// Persisted platform events (outbox / audit / metering source).
model PlatformEvent {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  branchId     String?  @map("branch_id")
  eventName    String   @map("event_name")
  payload      Json
  actorId      String?  @map("actor_id")
  actorRole    String?  @map("actor_role")
  resourceType String?  @map("resource_type")
  resourceId   String?  @map("resource_id")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([tenantId, eventName, createdAt])
  @@index([tenantId, resourceType, resourceId])
  @@map("platform_events")
}

model Encounter {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  patientId String   @map("patient_id")
  type      String
  status    String   @default("open")
  createdAt DateTime @default(now()) @map("created_at")

  patient Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  notes   ClinicalNote[]

  @@index([tenantId, patientId])
  @@map("encounters")
}

model ClinicalNote {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  encounterId String   @map("encounter_id")
  body        String
  createdAt   DateTime @default(now()) @map("created_at")

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([tenantId, encounterId])
  @@map("clinical_notes")
}

model Appointment {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  patientId     String   @map("patient_id")
  startAt       DateTime @map("start_at")
  endAt         DateTime @map("end_at")
  resourceLabel String   @map("resource_label")
  status        String   @default("scheduled")
  createdAt     DateTime @default(now()) @map("created_at")

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  waitlistEntries SchedulingWaitlistEntry[]

  @@index([tenantId, startAt])
  @@map("appointments")
}

/// Bookable doctors, rooms, and equipment for central scheduling.
model SchedulingResource {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  branchId     String   @map("branch_id")
  code         String
  label        String
  resourceType String   @default("doctor") @map("resource_type")
  department   String?
  isActive     Boolean  @default(true) @map("is_active")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([tenantId, branchId, code])
  @@index([tenantId, branchId, isActive])
  @@map("scheduling_resources")
}

/// Queue for slots when calendar is full — may link to booked appointment.
model SchedulingWaitlistEntry {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  branchId        String    @map("branch_id")
  patientId       String    @map("patient_id")
  resourceLabel   String    @map("resource_label")
  preferredStart  DateTime? @map("preferred_start")
  status          String    @default("waiting")
  priority        String    @default("routine")
  appointmentId   String?   @map("appointment_id")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([tenantId, branchId, status])
  @@map("scheduling_waitlist")
}

/// CRM lead pipeline — persisted on domain (not local-only).
model CrmLead {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  branchId     String    @map("branch_id")
  patientId    String?   @map("patient_id")
  opdVisitId   String?   @map("opd_visit_id")
  fullName     String    @map("full_name")
  phone        String?
  email        String?
  stage        String    @default("new_inquiry")
  specialty    String?
  packageName  String?   @map("package_name")
  ownerLabel   String?   @map("owner_label")
  channel      String?
  valueCents   Int?      @map("value_cents")
  priority     String    @default("medium")
  status       String    @default("open")
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  patient Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@index([tenantId, branchId, stage])
  @@index([tenantId, status])
  @@map("crm_leads")
}

/// Care journey / campaign definitions.
model CrmCampaign {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  branchId    String   @map("branch_id")
  name        String
  segment     String?
  channel     String?
  status      String   @default("draft")
  reachCount  Int      @default(0) @map("reach_count")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([tenantId, branchId, status])
  @@map("crm_campaigns")
}

/// Patient lifecycle touchpoints for CRM retention views.
model CrmLifecycleEvent {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  branchId   String   @map("branch_id")
  patientId  String   @map("patient_id")
  eventType  String   @map("event_type")
  journey    String?
  ownerLabel String?  @map("owner_label")
  riskLevel  String?  @map("risk_level")
  nextStep   String?  @map("next_step")
  detail     String?
  createdAt  DateTime @default(now()) @map("created_at")

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([tenantId, patientId, createdAt])
  @@map("crm_lifecycle_events")
}

/// CRM follow-up scheduling, reminders, and outcome tracking.
model CrmFollowUp {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  branchId        String    @map("branch_id")
  leadId          String?   @map("lead_id")
  patientId       String?   @map("patient_id")
  patientName     String    @map("patient_name")
  phone           String?
  assignedTo      String?   @map("assigned_to")
  followUpType    String    @default("call") @map("follow_up_type")
  scheduledAt     DateTime  @map("scheduled_at")
  completedAt     DateTime? @map("completed_at")
  missedAt        DateTime? @map("missed_at")
  status          String    @default("scheduled")
  outcome         String?
  notes           String?
  priority        String    @default("medium")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([tenantId, branchId, status, scheduledAt])
  @@index([tenantId, assignedTo, status])
  @@map("crm_follow_ups")
}

/// Treatment / service packages for counsellor proposals.
model CrmPackage {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  branchId        String    @map("branch_id")
  name            String
  category        String?
  description     String?
  basePriceCents  Int       @default(0) @map("base_price_cents")
  components      Json?
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  proposals CrmPackageProposal[]

  @@index([tenantId, branchId, isActive])
  @@map("crm_packages")
}

/// Package proposals sent to patients by counsellors.
model CrmPackageProposal {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  branchId        String    @map("branch_id")
  leadId          String?   @map("lead_id")
  patientId       String?   @map("patient_id")
  patientName     String    @map("patient_name")
  packageId       String?   @map("package_id")
  packageName     String    @map("package_name")
  proposedPriceCents Int    @default(0) @map("proposed_price_cents")
  counsellorLabel String?   @map("counsellor_label")
  status          String    @default("draft")
  notes           String?
  convertedAt     DateTime? @map("converted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  package CrmPackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)

  @@index([tenantId, branchId, status])
  @@map("crm_package_proposals")
}

/// Referral tracking — doctor, patient, and source referrals.
model CrmReferral {
  id                String   @id @default(cuid())
  tenantId          String   @map("tenant_id")
  branchId          String   @map("branch_id")
  patientId         String?  @map("patient_id")
  patientName       String   @map("patient_name")
  referralType      String   @default("source") @map("referral_type")
  referringDoctor   String?  @map("referring_doctor")
  referringHospital String?  @map("referring_hospital")
  referralSource    String?  @map("referral_source")
  specialty         String?
  status            String   @default("active")
  convertedToLead   Boolean  @default(false) @map("converted_to_lead")
  leadId            String?  @map("lead_id")
  notes             String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([tenantId, branchId, referralType, status])
  @@index([tenantId, referringDoctor])
  @@map("crm_referrals")
}

/// Counsellor task management.
model CrmTask {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  branchId     String    @map("branch_id")
  assignedTo   String?   @map("assigned_to")
  leadId       String?   @map("lead_id")
  patientName  String?   @map("patient_name")
  taskType     String    @default("follow_up") @map("task_type")
  title        String
  description  String?
  status       String    @default("pending")
  priority     String    @default("medium")
  dueAt        DateTime? @map("due_at")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([tenantId, branchId, assignedTo, status])
  @@index([tenantId, branchId, dueAt])
  @@map("crm_tasks")
}

model Invoice {
  id             String    @id @default(cuid())
  tenantId       String    @map("tenant_id")
  branchId       String    @map("branch_id")
  patientId      String    @map("patient_id")
  encounterId    String?   @map("encounter_id")
  opdVisitId       String?   @map("opd_visit_id")
  ipdAdmissionId   String?   @map("ipd_admission_id")
  amountCents    Int       @map("amount_cents")
  paidCents      Int       @default(0) @map("paid_cents")
  currency       String    @default("INR")
  gstRateBps     Int       @default(0) @map("gst_rate_bps")
  status         String    @default("draft")
  lineItems      Json      @default("[]") @map("line_items")
  paymentMethod  String?   @map("payment_method")
  receiptNumber  String?   @unique @map("receipt_number")
  version        Int       @default(0)
  corporatePayer Boolean   @default(false) @map("corporate_payer")
  insuranceMode  String    @default("self") @map("insurance_mode")
  requiresApproval Boolean @default(false) @map("requires_approval")
  settledAt      DateTime? @map("settled_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  patient     Patient              @relation(fields: [patientId], references: [id], onDelete: Cascade)
  transitions InvoiceTransition[]
  payments    PaymentRecord[]
  chargeLines InvoiceChargeLine[]

  ipdAdmission IpdAdmission? @relation(fields: [ipdAdmissionId], references: [id], onDelete: SetNull)

  @@index([tenantId, opdVisitId])
  @@index([tenantId, ipdAdmissionId])
  @@index([tenantId, createdAt])
  @@map("invoices")
}

/// Idempotent operational charge lines — live financial layer during patient journey.
model InvoiceChargeLine {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  invoiceId       String    @map("invoice_id")
  idempotencyKey  String    @map("idempotency_key")
  chargeCode      String?   @map("charge_code")
  description     String
  amountCents     Int       @map("amount_cents")
  status          String    @default("active")
  sourceModule    String    @map("source_module")
  sourceAction    String    @map("source_action")
  sourceRefId     String?   @map("source_ref_id")
  metadata        Json?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  reversedAt      DateTime? @map("reversed_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([tenantId, idempotencyKey])
  @@index([invoiceId, status])
  @@map("invoice_charge_lines")
}

model InvoiceTransition {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  invoiceId String   @map("invoice_id")
  action    String
  fromState String   @map("from_state")
  toState   String   @map("to_state")
  actorId   String?  @map("actor_id")
  actorRole String?  @map("actor_role")
  reason    String?
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId, invoiceId, createdAt])
  @@map("invoice_transitions")
}

model PaymentRecord {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  invoiceId    String   @map("invoice_id")
  kind         String
  amountCents  Int      @map("amount_cents")
  method       String
  reference    String?
  reason       String?
  actorId      String?  @map("actor_id")
  createdAt    DateTime @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId, invoiceId])
  @@map("payment_records")
}

/// Authoritative Lab/LIMS diagnostic order lifecycle.
model LabDiagnosticOrder {
  id               String    @id @default(cuid())
  tenantId         String    @map("tenant_id")
  branchId         String    @map("branch_id")
  patientId        String    @map("patient_id")
  encounterId      String?   @map("encounter_id")
  opdVisitId       String?   @map("opd_visit_id")
  externalRef      String?   @map("external_ref")
  tests            String
  category         String    @default("General")
  priority         String    @default("Routine")
  orderingDoctor   String    @map("ordering_doctor")
  state            String    @default("ordered")
  sampleId         String?   @map("sample_id")
  sampleBarcode    String?   @map("sample_barcode")
  isCritical       Boolean   @default(false) @map("is_critical")
  criticalAckAt    DateTime? @map("critical_ack_at")
  results          Json?
  amountCents      Int       @default(0) @map("amount_cents")
  billingChargeKey String?   @map("billing_charge_key")
  version          Int       @default(0)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  completedAt      DateTime? @map("completed_at")

  patient     Patient                 @relation(fields: [patientId], references: [id], onDelete: Cascade)
  transitions LabOrderTransition[]

  @@index([tenantId, opdVisitId, state])
  @@index([tenantId, patientId, createdAt])
  @@map("lab_diagnostic_orders")
}

model LabOrderTransition {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  labOrderId String   @map("lab_order_id")
  action     String
  fromState  String   @map("from_state")
  toState    String   @map("to_state")
  actorId    String?  @map("actor_id")
  actorRole  String?  @map("actor_role")
  reason     String?
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  order LabDiagnosticOrder @relation(fields: [labOrderId], references: [id], onDelete: Cascade)

  @@index([tenantId, labOrderId, createdAt])
  @@map("lab_order_transitions")
}

/// Authoritative radiology study order lifecycle.
model RadiologyStudyOrder {
  id               String    @id @default(cuid())
  tenantId         String    @map("tenant_id")
  branchId         String    @map("branch_id")
  patientId        String    @map("patient_id")
  encounterId      String?   @map("encounter_id")
  opdVisitId       String?   @map("opd_visit_id")
  externalRef      String?   @map("external_ref")
  study            String
  modality         String    @default("X-Ray")
  priority         String    @default("Routine")
  orderingDoctor   String    @map("ordering_doctor")
  state            String    @default("ordered")
  isCritical       Boolean   @default(false) @map("is_critical")
  criticalAckAt    DateTime? @map("critical_ack_at")
  report           Json?
  amountCents      Int       @default(0) @map("amount_cents")
  billingChargeKey String?   @map("billing_charge_key")
  version          Int       @default(0)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  completedAt      DateTime? @map("completed_at")

  patient     Patient                    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  transitions RadiologyOrderTransition[]

  @@index([tenantId, opdVisitId, state])
  @@index([tenantId, patientId, createdAt])
  @@map("radiology_study_orders")
}

model RadiologyOrderTransition {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  radiologyOrderId String  @map("radiology_order_id")
  action          String
  fromState       String   @map("from_state")
  toState         String   @map("to_state")
  actorId         String?  @map("actor_id")
  actorRole       String?  @map("actor_role")
  reason          String?
  metadata        Json?
  createdAt       DateTime @default(now()) @map("created_at")

  order RadiologyStudyOrder @relation(fields: [radiologyOrderId], references: [id], onDelete: Cascade)

  @@index([tenantId, radiologyOrderId, createdAt])
  @@map("radiology_order_transitions")
}

/// Branch pharmacy stock (authoritative for reservations).
model PharmacyStockItem {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  branchId     String   @map("branch_id")
  drug         String
  generic      String   @default("")
  batch        String
  expiry       DateTime
  qtyOnHand    Int      @map("qty_on_hand")
  qtyReserved  Int      @default(0) @map("qty_reserved")
  isControlled Boolean  @default(false) @map("is_controlled")
  unitPriceCents Int    @default(12000) @map("unit_price_cents")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  reservations PharmacyInventoryReservation[]

  @@index([tenantId, branchId, drug])
  @@map("pharmacy_stock_items")
}

/// Authoritative pharmacy prescription fulfillment lifecycle.
model PharmacyFulfillment {
  id                  String    @id @default(cuid())
  tenantId            String    @map("tenant_id")
  branchId            String    @map("branch_id")
  patientId           String    @map("patient_id")
  encounterId         String?   @map("encounter_id")
  opdVisitId          String?   @map("opd_visit_id")
  externalRef         String?   @map("external_ref")
  prescribingDoctor   String    @map("prescribing_doctor")
  department          String    @default("")
  priority            String    @default("Routine")
  medications         Json
  state               String    @default("prescribed")
  isControlled        Boolean   @default(false) @map("is_controlled")
  controlledApproved  Boolean   @default(false) @map("controlled_approved")
  dispensedSnapshot   Json?     @map("dispensed_snapshot")
  amountCents         Int       @default(0) @map("amount_cents")
  billingChargeKey    String?   @map("billing_charge_key")
  version             Int       @default(0)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  completedAt         DateTime? @map("completed_at")

  patient      Patient                        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  transitions  PharmacyFulfillmentTransition[]
  reservations PharmacyInventoryReservation[]

  @@index([tenantId, opdVisitId, state])
  @@index([tenantId, patientId, createdAt])
  @@map("pharmacy_fulfillments")
}

model PharmacyFulfillmentTransition {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  fulfillmentId String   @map("fulfillment_id")
  action        String
  fromState     String   @map("from_state")
  toState       String   @map("to_state")
  actorId       String?  @map("actor_id")
  actorRole     String?  @map("actor_role")
  reason        String?
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")

  fulfillment PharmacyFulfillment @relation(fields: [fulfillmentId], references: [id], onDelete: Cascade)

  @@index([tenantId, fulfillmentId, createdAt])
  @@map("pharmacy_fulfillment_transitions")
}

model PharmacyInventoryReservation {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  fulfillmentId String   @map("fulfillment_id")
  stockItemId   String   @map("stock_item_id")
  qtyReserved   Int      @map("qty_reserved")
  status        String   @default("active")
