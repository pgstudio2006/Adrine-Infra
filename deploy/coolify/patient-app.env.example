# Coolify → adrine-patient-app → Build-time environment (Dockerfile ARGs)
# Domain: https://book.adrine.in
# Dockerfile: /apps/patient-app/Dockerfile (build context = repo root)
# Port expose: 3000 (Traefik only — do not map 3000:3000 on host if port 80 is taken)

NEXT_PUBLIC_PLATFORM_RUNTIME=true
NEXT_PUBLIC_KERNEL_API_URL=https://kernel.adrine.in
NEXT_PUBLIC_DOMAIN_API_URL=https://domain.adrine.in
NEXT_PUBLIC_DEV_TENANT_ID=tenant_navayu

