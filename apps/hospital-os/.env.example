# Adrine platform APIs (wire progressively: auth → config → domain)
VITE_KERNEL_API_URL=http://localhost:3001
VITE_DOMAIN_API_URL=http://localhost:3002
VITE_API_BASE_URL=http://localhost:3002
VITE_API_PROVIDER=nest

# Dev tenant (until kernel signup flow exists)
VITE_DEV_TENANT_ID=tenant_dev

# Enable authoritative OPD runtime (domain-api + kernel-api must be running)
VITE_PLATFORM_RUNTIME=true

# Local dev only: show sample/demo rows on unwired screens (default off — production never uses demo data)
# VITE_ALLOW_DEMO_DATA=false
# Vercel static demo: leave VITE_PLATFORM_RUNTIME unset (or false). Role-picker login works without password.
# If platform runtime is on in production, set VITE_ALLOW_DEMO_LOGIN=true only for hosted sales demos.
# VITE_ALLOW_DEMO_LOGIN=true

# AI scribe and MSK summaries use OPENROUTER_API_KEY on domain-api only — never in the browser bundle.

# Production auth — kernel dev-login or OIDC (see ops/PRODUCTION_AUTH.md)
# VITE_OIDC_ISSUER=
# VITE_OIDC_CLIENT_ID=hospital-os
# VITE_OIDC_REDIRECT_URI=http://localhost:3100/callback

# --- Local dev CORS (hospital-os only) ---
# Vite dev server: http://localhost:3100
# kernel-api and domain-api must allow that origin (see services/*/main.ts or env CORS_ORIGINS).
# Typical local values:
#   CORS_ORIGINS=http://localhost:3100,http://127.0.0.1:3100
# If login or API calls fail with "blocked by CORS", verify both APIs are up and origins match.
# Patient app (port 3101) is separate — do not mix its env into hospital-os.
# Intake links copied from reception registration:
# VITE_PATIENT_APP_URL=http://localhost:3101
